# Copy this file to ".env" and adjust the values, or set these as real
# environment variables before starting the server. Real environment
# variables take precedence over a .env file.

# MongoDB connection string (keep this secret in production)
MONGODB_URL=mongodb://localhost:27017/

# Database / collection names
MONGODB_DB_NAME=FamilyTree
MONGODB_MEMBERS_COLLECTION=Members
MONGODB_RELATIONSHIPS_COLLECTION=Relationships

# Port the API server listens on
PORT=3012
